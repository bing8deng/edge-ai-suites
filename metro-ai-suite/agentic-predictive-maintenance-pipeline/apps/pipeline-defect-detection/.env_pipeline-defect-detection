# Pipeline Defect Detection — Environment Configuration
# Copy this file and set values for your deployment
# Usage: ./setup.sh --use-case pipeline-defect-detection

# ── Deployment ────────────────────────────────────────────────────────────────
USE_CASE_ID=pipeline-defect-detection
APP_HOST_PORT=8080
# Host/IP shown in the "Application started" URL and used for any host-networked
# access. Defaults to localhost if left unset — override with your machine's LAN
# IP if you need to reach the dashboard from another device.
HOST_IP=localhost

# API key used by agent/storage mutating endpoints (X-API-Key header)
# Change this value before exposing the stack beyond localhost/trusted networks.
APM_API_KEY=change-me-apm-key

# ── LLM / VLM ────────────────────────────────────────────────────────────────
# Set LLM_MODE=fallback to run without an LLM (rule-based operation)
LLM_MODE=llm
LLM_MODEL_NAME=microsoft/Phi-4-mini-instruct
LLM_DEVICE=CPU
LLM_WEIGHT_FORMAT=int4
LLM_PORT=8010

# ── DL Streamer ───────────────────────────────────────────────────────────────
DL_DEVICE=CPU
PIPELINE_SERVER_PORT=8554

# ── Model Download ────────────────────────────────────────────────────────────
# HuggingFace token — required for gated models (e.g. microsoft/Phi-4-mini-instruct)
# 1. Accept the model license at https://huggingface.co/microsoft/Phi-4-mini-instruct
# 2. Generate a token at https://huggingface.co/settings/tokens
# HUGGINGFACEHUB_API_TOKEN=hf_...
MODEL_DOWNLOAD_PORT=8200

# ── MQTT ─────────────────────────────────────────────────────────────────────
MQTT_HOST=mqtt-broker
MQTT_PORT=1883
MQTT_TOPIC=dlstreamer/detections

# ── Pipeline execution model ──────────────────────────────────────────────────
# Clicking "Run Pipeline" runs one full detect-then-reason cycle: DL Streamer
# processes the (finite) source video once end-to-end, then the agent
# pipeline (policy -> analysis -> evidence -> ticketing) reasons over exactly
# the detections produced by that run. Only one run may be in flight at a
# time (a concurrent "Run Pipeline" call is rejected with 409). This mirrors
# the reference CLI's batch model; live/continuous background detection is
# planned for a future iteration.

# ── Telemetry ─────────────────────────────────────────────────────────────────
METRICS_PORT=9091
PROMETHEUS_PORT=9090

# ── Registry (leave empty to use local builds) ───────────────────────────────
REGISTRY=
TAG=latest


# Set automatically by scripts/download_llm_model.sh
LLM_MODEL_PATH=./apps/pipeline-defect-detection/models/llm_model_pipeline-defect-detection/openvino_models/cpu/int4/microsoft/Phi-4-mini-instruct
