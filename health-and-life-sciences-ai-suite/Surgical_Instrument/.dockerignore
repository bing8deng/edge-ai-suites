models/
datasets/
videos/
out/
model_cache/

# Dev-only scratch and legacy MVP mock (not shipped)
_dev_notes/
backend_mvp/
poc/
.venv-mock/

# VCS + editor
.git/
.gitignore
.vscode/
.idea/

# Compose / docker
docker-compose*.yaml
Dockerfile
.dockerignore
