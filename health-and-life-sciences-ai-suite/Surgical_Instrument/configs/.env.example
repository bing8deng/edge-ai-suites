# Surgical Instrument — environment template.
# Copy to .env (gitignored) and set real values before `make up`.

# MQTT broker credentials (used by mosquitto + pipeline + backend).
MQTT_USERNAME=surgical
MQTT_PASSWORD=changeme

# Inference device for the polyp-detection pipeline.
# One of: CPU | GPU | NPU
DETECTION_DEVICE=GPU

# Host-side group IDs for /dev/dri and /dev/video* access from the pipeline container.
# Find with: getent group render | cut -d: -f3   and   getent group video | cut -d: -f3
RENDER_GID=992
VIDEO_GID=44

# UI host port (only port published to the host).
UI_HOST_PORT=8080

# Metrics-collector image — pin once published.
METRICS_IMAGE=intel/hl-ai-metrics-collector:latest
