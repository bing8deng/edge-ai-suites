--- a/packages/ros-camera/src/snapshot.ts
+++ b/packages/ros-camera/src/snapshot.ts
@@ -291,7 +291,25 @@ export function cameraSnapshotFromPlainMessage(
   messageType: "Image" | "CompressedImage",
   msg: Record<string, unknown>,
 ): CameraSnapshotPayload {
-  if (messageType === "Image") {
+  // The message structure is the source of truth for how to decode it, regardless of
+  // the requested messageType (which may be a wrong guess from the model/topic name).
+  // A raw sensor_msgs/Image carries width/height/encoding/step and no `format`; a
+  // sensor_msgs/CompressedImage carries a `format` string and no `encoding`/`width`.
+  // Auto-correct so a raw Image is never mis-decoded as a (non-existent) compressed
+  // blob (which would emit garbage bytes mislabeled image/jpeg) and vice-versa.
+  const looksRaw =
+    msg["encoding"] !== undefined &&
+    msg["width"] !== undefined &&
+    msg["height"] !== undefined &&
+    msg["format"] === undefined;
+  const looksCompressed = typeof msg["format"] === "string" && msg["encoding"] === undefined;
+  const effectiveType: "Image" | "CompressedImage" = looksRaw
+    ? "Image"
+    : looksCompressed
+      ? "CompressedImage"
+      : messageType;
+
+  if (effectiveType === "Image") {
     const rawBuf = coerceRosImageDataToBuffer(msg["data"]);
     const encoding = String((msg["encoding"] as string) ?? "rgb8");
     const w = rosNumericField(msg["width"], "width");
