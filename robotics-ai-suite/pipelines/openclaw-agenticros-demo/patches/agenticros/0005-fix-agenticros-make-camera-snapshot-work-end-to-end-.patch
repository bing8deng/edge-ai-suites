diff --git a/packages/agenticros/src/history/strip-camera-image.ts b/packages/agenticros/src/history/strip-camera-image.ts
new file mode 100644
index 0000000..3ab6673
--- /dev/null
+++ b/packages/agenticros/src/history/strip-camera-image.ts
@@ -0,0 +1,76 @@
+import type { OpenClawPluginApi } from "../plugin-api.js";
+
+/** Tool names whose image payloads should not be retained in the session transcript. */
+const IMAGE_TOOL_NAMES = new Set(["ros2_camera_snapshot"]);
+
+interface PersistableContentBlock {
+  type: string;
+  data?: unknown;
+  text?: string;
+  mimeType?: unknown;
+  [key: string]: unknown;
+}
+
+interface PersistableMessage {
+  content?: unknown;
+  [key: string]: unknown;
+}
+
+interface ToolResultPersistEvent {
+  toolName?: string;
+  message?: PersistableMessage;
+}
+
+/**
+ * Register the `tool_result_persist` hook to strip heavy camera image payloads from
+ * the persisted session transcript.
+ *
+ * Why: a full-resolution camera frame (e.g. a 640×480 PNG ≈ 370KB base64) is sent to
+ * the vision model in the turn that captured it — that must stay full-res for accurate
+ * analysis. But once persisted into the conversation, the inline base64 (a) exceeds
+ * OpenClaw's per-message history limit so the whole message is dropped from the UI as
+ * "[chat.history omitted: message too large]", and (b) bloats the context that every
+ * subsequent turn must reprocess. This hook runs AFTER the capturing turn's model call
+ * has already consumed the image, and rewrites only the PERSISTED copy: it removes the
+ * base64 `data` from image blocks and leaves a short text marker. The model's analysis
+ * is unaffected; the transcript stays small; the image never re-enters context.
+ *
+ * The hook must be synchronous (it runs on the transcript-append hot path).
+ */
+export function registerCameraImageHistoryStripper(api: OpenClawPluginApi): void {
+  const on = api.on as unknown as (
+    hookName: string,
+    handler: (event: ToolResultPersistEvent) => { message: PersistableMessage } | undefined,
+  ) => void;
+
+  try {
+    on("tool_result_persist", (event) => {
+      const toolName = event?.toolName;
+      if (!toolName || !IMAGE_TOOL_NAMES.has(toolName)) return undefined;
+
+      const message = event?.message;
+      const content = message?.content;
+      if (!Array.isArray(content)) return undefined;
+
+      let changed = false;
+      const nextContent = content.map((raw) => {
+        const block = raw as PersistableContentBlock;
+        if (block?.type === "image" && typeof block.data === "string" && block.data.length > 0) {
+          changed = true;
+          // Replace the image block with a tiny text marker. The image was already
+          // shown/analyzed in the capturing turn; we just keep a breadcrumb in history.
+          return { type: "text", text: "[camera image omitted from history — already analyzed]" };
+        }
+        return block;
+      });
+
+      if (!changed) return undefined;
+      return { message: { ...message, content: nextContent } };
+    });
+    api.logger.info("AgenticROS: registered tool_result_persist hook (camera image history stripper)");
+  } catch (e) {
+    api.logger.warn(
+      `AgenticROS: could not register tool_result_persist hook: ${e instanceof Error ? e.message : String(e)}`,
+    );
+  }
+}
